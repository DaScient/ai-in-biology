---
import APILayout from '../../layouts/APILayout.astro';

const title = 'API Playground - AI in Biological Sciences';
const description = 'Test API endpoints interactively. Predict protein structures, analyze single-cell data, and more.';
---

<APILayout title={title} description={description}>
  <div class="api-playground">
    <header class="playground-header">
      <h1>🔬 API Playground</h1>
      <p class="subtitle">
        Test endpoints in real-time. Get your API key at
        <a href="https://dascient.com/api">dascient.com/api</a>
      </p>
      <div class="api-key-input">
        <label for="api-key">API Key:</label>
        <input
          type="password"
          id="api-key"
          placeholder="sk-..."
          autocomplete="off"
        />
        <button id="save-key" class="btn-secondary">Save</button>
      </div>
    </header>

    <div class="endpoint-grid">
      <aside class="endpoint-sidebar">
        <nav class="endpoint-nav">
          <h3>Endpoints</h3>
          <ul>
            <li><a href="#protein-fold" class="active">Protein /fold</a></li>
            <li><a href="#protein-design">Protein /design</a></li>
            <li><a href="#scell-embed">Single-Cell /embed</a></li>
            <li><a href="#scell-trajectory">Single-Cell /trajectory</a></li>
            <li><a href="#genomics-variant">Genomics /variant</a></li>
            <li><a href="#ecology-sdm">Ecology /sdm</a></li>
            <li><a href="#clinical-diagnosis">Clinical /diagnosis</a></li>
            <li><a href="#drug-docking">Drug /docking</a></li>
          </ul>
        </nav>
        <div class="example-snippets">
          <h4>📋 Examples</h4>
          <button class="example-btn" data-example="p53">p53 sequence</button>
          <button class="example-btn" data-example="pbmc">Single-cell sample</button>
          <button class="example-btn" data-example="brca1">BRCA1 mutation</button>
        </div>
      </aside>

      <main class="playground-main">
        <!-- Protein Fold Endpoint -->
        <section id="protein-fold" class="endpoint-card">
          <div class="endpoint-header">
            <span class="method post">POST</span>
            <code>/api/v1/protein/fold</code>
            <span class="status-badge">active</span>
          </div>

          <div class="endpoint-description">
            <p>Predict protein 3D structure from amino acid sequence using AlphaFold2/ESMFold.</p>
          </div>

          <div class="request-section">
            <h4>Request</h4>
            <div class="code-tabs">
              <button class="tab active" data-tab="json">JSON</button>
              <button class="tab" data-tab="curl">cURL</button>
              <button class="tab" data-tab="python">Python</button>
            </div>

            <div class="tab-content active" data-tab="json">
              <pre class="request-json"><code>{
  "sequence": "",
  "model_type": "alphafold2",
  "return_plddt": true
}</code></pre>
            </div>

            <div class="tab-content" data-tab="curl">
              <pre class="request-curl"><code>curl -X POST "https://api.bioai.dascient.com/api/v1/protein/fold" \
  -H "X-API-Key: YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '{
    "sequence": "MEEPQSDPSVEPPLSQETFSDLWKLLPENN",
    "model_type": "alphafold2"
  }'</code></pre>
            </div>

            <div class="tab-content" data-tab="python">
              <pre class="request-python"><code>import requests

response = requests.post(
    "https://api.bioai.dascient.com/api/v1/protein/fold",
    headers={"X-API-Key": "YOUR_API_KEY"},
    json={"sequence": "MEEPQSDPSVEPPLSQETFSDLWKLLPENN"}
)
pdb = response.json()["pdb_content"]</code></pre>
            </div>
          </div>

          <div class="try-it-section">
            <h4>🔧 Try It</h4>
            <textarea id="protein-sequence" rows="4" placeholder="Enter protein sequence...">MEEPQSDPSVEPPLSQETFSDLWKLLPENN</textarea>
            <div class="model-select">
              <label>Model:</label>
              <select id="protein-model">
                <option value="alphafold2">AlphaFold2 (most accurate)</option>
                <option value="esmfold">ESMFold (fastest)</option>
                <option value="rosettafold">RoseTTAFold (open)</option>
              </select>
            </div>
            <button id="run-protein-fold" class="btn-primary">🚀 Predict Structure</button>

            <div id="protein-result" class="result-container" style="display: none;">
              <div class="result-header">
                <h4>Results</h4>
                <div class="confidence-badge" id="plddt-value"></div>
              </div>
              <div class="result-content">
                <pre id="protein-pdb" class="pdb-output"></pre>
                <div class="visualization-options">
                  <button id="view-3d" class="btn-sm">🔍 View in 3D (mol* viewer)</button>
                  <button id="download-pdb" class="btn-sm">💾 Download PDB</button>
                </div>
              </div>
            </div>

            <div id="protein-loading" class="loading" style="display: none;">
              <div class="spinner"></div>
              <p>Predicting structure... (10-30 seconds)</p>
            </div>
          </div>
        </section>

        <!-- Single-Cell Embed Endpoint -->
        <section id="scell-embed" class="endpoint-card">
          <div class="endpoint-header">
            <span class="method post">POST</span>
            <code>/api/v1/scell/embed</code>
            <span class="status-badge">beta</span>
          </div>

          <div class="endpoint-description">
            <p>Generate low-dimensional embeddings from single-cell expression data using scVI or scGPT.</p>
          </div>

          <div class="try-it-section">
            <h4>🔧 Try It</h4>
            <div class="data-input">
              <label>Upload expression matrix:</label>
              <input type="file" id="scell-file" accept=".h5ad,.csv,.mtx" />
              <span class="file-hint">or use sample dataset</span>
              <button id="load-sample-scell" class="btn-outline-sm">Load Sample (PBMC 3k)</button>
            </div>

            <div class="model-select">
              <label>Model:</label>
              <select id="scell-model">
                <option value="scvi">scVI (VAE with ZINB)</option>
                <option value="scgpt">scGPT (Transformer)</option>
                <option value="geneformer">Geneformer (Foundation)</option>
              </select>
            </div>

            <button id="run-scell-embed" class="btn-primary">📊 Generate Embeddings</button>

            <div id="scell-result" style="display: none;">
              <div id="umap-plot" class="plot-container"></div>
              <div class="embedding-stats">
                <span id="n-cells-display"></span>
                <span id="n-genes-display"></span>
                <span id="sparsity-display"></span>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>
  </div>

  <script>
    // Interactive API tester logic
    document.addEventListener('DOMContentLoaded', () => {
      // Store API key
      const saveKeyBtn = document.getElementById('save-key');
      const apiKeyInput = document.getElementById('api-key') as HTMLInputElement | null;

      // Load saved key
      const savedKey = localStorage.getItem('bioai_api_key');
      if (savedKey && apiKeyInput) {
        apiKeyInput.value = savedKey;
      }

      saveKeyBtn?.addEventListener('click', () => {
        if (apiKeyInput) {
          localStorage.setItem('bioai_api_key', apiKeyInput.value);
          alert('API key saved!');
        }
      });

      // Protein fold endpoint
      const runBtn = document.getElementById('run-protein-fold');
      runBtn?.addEventListener('click', async () => {
        const apiKey = localStorage.getItem('bioai_api_key');
        if (!apiKey) {
          alert('Please enter and save your API key first');
          return;
        }

        const sequenceEl = document.getElementById('protein-sequence') as HTMLTextAreaElement | null;
        const modelEl = document.getElementById('protein-model') as HTMLSelectElement | null;
        const sequence = sequenceEl?.value ?? '';
        const model = modelEl?.value ?? 'alphafold2';

        // Show loading
        const loadingEl = document.getElementById('protein-loading');
        const resultEl = document.getElementById('protein-result');
        if (loadingEl) loadingEl.style.display = 'block';
        if (resultEl) resultEl.style.display = 'none';

        try {
          const response = await fetch('https://api.bioai.dascient.com/api/v1/protein/fold', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-API-Key': apiKey
            },
            body: JSON.stringify({
              sequence: sequence,
              model_type: model,
              return_plddt: true
            })
          });

          const data = await response.json();

          // Display result
          if (loadingEl) loadingEl.style.display = 'none';
          if (resultEl) resultEl.style.display = 'block';
          const pdbEl = document.getElementById('protein-pdb');
          if (pdbEl) pdbEl.textContent = (data.pdb_content || '').substring(0, 2000) + '...';

          // Show confidence
          const plddt: number[] = data.confidence || [];
          const avgPlddt = plddt.length > 0 ? plddt.reduce((a, b) => a + b, 0) / plddt.length : 0;
          const badgeEl = document.getElementById('plddt-value');
          if (badgeEl) badgeEl.innerHTML = `📊 pLDDT: ${avgPlddt.toFixed(1)}`;

          // Download handler
          const downloadBtn = document.getElementById('download-pdb');
          if (downloadBtn) {
            downloadBtn.onclick = () => {
              const blob = new Blob([data.pdb_content], { type: 'text/plain' });
              const url = URL.createObjectURL(blob);
              const a = document.createElement('a');
              a.href = url;
              a.download = 'predicted_structure.pdb';
              a.click();
              URL.revokeObjectURL(url);
            };
          }

        } catch (error) {
          console.error('API error:', error);
          if (loadingEl) loadingEl.style.display = 'none';
          alert('Error: ' + (error as Error).message);
        }
      });

      // Example buttons
      document.querySelectorAll<HTMLButtonElement>('.example-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const example = btn.dataset.example;
          if (example === 'p53') {
            const seqEl = document.getElementById('protein-sequence') as HTMLTextAreaElement | null;
            if (seqEl) seqEl.value = 'MEEPQSDPSVEPPLSQETFSDLWKLLPENN';
          }
        });
      });

      // Tab switching
      document.querySelectorAll<HTMLButtonElement>('.tab').forEach(tab => {
        tab.addEventListener('click', () => {
          const parent = tab.closest('.request-section');
          if (!parent) return;
          const tabId = tab.dataset.tab;

          // Update active tab
          parent.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          // Show content
          parent.querySelectorAll('.tab-content').forEach(content => {
            content.classList.remove('active');
          });
          const target = parent.querySelector(`.tab-content[data-tab="${tabId}"]`);
          target?.classList.add('active');
        });
      });
    });
  </script>
</APILayout>

<style is:global>
  .api-playground {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .playground-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .playground-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-secondary);
  }

  .api-key-input {
    margin-top: 1rem;
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    background: var(--bg-tertiary);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
  }

  .api-key-input input {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    padding: 0.25rem 0.5rem;
    font-family: monospace;
    width: 250px;
  }

  .endpoint-grid {
    display: flex;
    gap: 2rem;
  }

  .endpoint-sidebar {
    width: 260px;
    position: sticky;
    top: 2rem;
    height: fit-content;
  }

  .endpoint-nav ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .endpoint-nav li {
    margin: 0.5rem 0;
  }

  .endpoint-nav a {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.2s;
  }

  .endpoint-nav a:hover,
  .endpoint-nav a.active {
    background: var(--accent-muted);
    color: var(--accent);
  }

  .playground-main {
    flex: 1;
  }

  .endpoint-card {
    background: var(--card-bg);
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-md);
  }

  .endpoint-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .method {
    font-family: monospace;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
  }

  .method.post {
    background: #2b825b;
    color: white;
  }

  .method.get {
    background: #1f6f8b;
    color: white;
  }

  .status-badge {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
    background: var(--bg-tertiary);
  }

  .status-badge.beta {
    background: #e6a700;
    color: #1a1a1a;
  }

  .code-tabs {
    display: flex;
    gap: 0.5rem;
    margin: 1rem 0 0.5rem;
  }

  .tab {
    background: none;
    border: none;
    padding: 0.5rem 1rem;
    cursor: pointer;
    border-radius: 0.5rem;
    color: var(--text-secondary);
  }

  .tab.active {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  .tab-content pre {
    background: var(--code-bg);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
  }

  .try-it-section {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .try-it-section textarea {
    width: 100%;
    font-family: monospace;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.75rem;
    margin: 0.5rem 0;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    cursor: pointer;
    font-weight: 600;
    margin-top: 1rem;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
  }

  .result-container {
    margin-top: 1rem;
    background: var(--code-bg);
    border-radius: 0.5rem;
    padding: 1rem;
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .confidence-badge {
    background: var(--bg-tertiary);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.875rem;
  }

  .pdb-output {
    max-height: 300px;
    overflow-y: auto;
    font-size: 0.75rem;
  }

  .loading {
    text-align: center;
    padding: 2rem;
  }

  .spinner {
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 1s linear infinite;
    margin: 0 auto 1rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .endpoint-grid {
      flex-direction: column;
    }

    .endpoint-sidebar {
      width: 100%;
      position: static;
    }

    .endpoint-nav ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
  }
</style>
