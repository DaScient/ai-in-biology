# Application Settings
APP_ENV=development
APP_DEBUG=true
# Generate a strong random secret key: openssl rand -hex 32
APP_SECRET_KEY=replace-with-a-strong-random-secret-key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_WORKERS=4
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aibio
REDIS_URL=redis://localhost:6379/0

# External AI Services
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_TOKEN=your-huggingface-token

# Model Paths
MODEL_CACHE_DIR=/data/pretrained
ALPHAFOLD_DATA_DIR=/data/alphafold

# Jupyter
JUPYTER_PORT=8888
JUPYTER_TOKEN=your-jupyter-token

# Monitoring
WANDB_API_KEY=your-wandb-api-key
MLFLOW_TRACKING_URI=http://localhost:5000

# Cloud Storage (optional)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=ai-bio-data

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
